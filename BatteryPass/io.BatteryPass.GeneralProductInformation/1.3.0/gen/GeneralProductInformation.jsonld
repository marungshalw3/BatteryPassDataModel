      "@value" : "battery serial number"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "Serial number of the individual battery item (individual-level identification). Batteries shall bear a batch or serial number, or product number or another element allowing their identification (Art. 38(6)).\n\nDIN DKE Spec chapter reference: 6.1.2.2"
    },
    "samm:characteristic" : {
      "@id" : "samm-c:Text"
