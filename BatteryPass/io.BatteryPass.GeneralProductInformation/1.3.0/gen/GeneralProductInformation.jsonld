    "samm-c:baseCharacteristic" : {
      "@id" : "samm-c:Text"
    },
    "samm-c:constraint" : {
      "@id" : "urn:samm:io.BatteryPass.GeneralProductInformation:1.3.0#ValidEmailAddress"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.GeneralProductInformation:1.3.0#ValidEmailAddress",
    "@type" : "samm-c:RegularExpressionConstraint",
    "samm:value" : "^[w.-]+@[w.-]+.[A-Za-z]{2,}$"
  }, {
    "@id" : "urn:samm:io.BatteryPass.GeneralProductInformation:1.3.0#puttingIntoService",
    "@type" : "samm:Property",
    "samm:description" : {
      "@language" : "en",
      "@value" : "Where appropriate, the battery passport must include information on the date of putting the battery into service. BR Annex VI Part A (1); Art. 3(33); Art. 38(7); ESPR Art. 2(32)\n\nDIN DKE Spec chapter reference: 6.1.3.3"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.GeneralProductInformation:1.3.0#PuttingIntoServiceDateTime"
    }
  }, {
