                <aas:type>GlobalReference</aas:type>
                <aas:value>urn:samm:io.BatteryPass.Labels:1.3.0#labels</aas:value>
              </aas:key>
            </aas:keys>
          </aas:semanticId>
          <aas:orderRelevant>false</aas:orderRelevant>
