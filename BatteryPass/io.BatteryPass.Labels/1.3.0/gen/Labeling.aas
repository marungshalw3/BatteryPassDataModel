        <aas:submodelElementList>
          <aas:idShort>LabelingEntity</aas:idShort>
          <aas:description>
            <aas:langStringTextType>
              <aas:language>en</aas:language>
              <aas:text>'Separate collection' or 'WEEE label' indicating that a product should not be discarded as unsorted waste but must be sent to separate collection facilities for recovery and recycling. To be printed on the physical label and displayed via the battery passport, suggested to be translated also to text to ensure machine readability.

DIN DKE Spec chapter reference: 

6.2.2 Separate collection
6.2.3 Material symbol for Cadmium and Lead
6.2.4 Carbon Footprint perfromance class
6.2.5 Extinguishing agent</aas:text>
            </aas:langStringTextType>
          </aas:description>
          <aas:semanticId>
            <aas:type>ExternalReference</aas:type>
            <aas:keys>
