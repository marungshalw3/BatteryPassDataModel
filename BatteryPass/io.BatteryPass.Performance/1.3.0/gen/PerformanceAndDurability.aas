            <aas:submodelElementCollection>
              <aas:idShort>StateOfChargeEntity</aas:idShort>
              <aas:displayName>
                <aas:langStringNameType>
                  <aas:language>en</aas:language>
                  <aas:text>SoC</aas:text>
                </aas:langStringNameType>
              </aas:displayName>
              <aas:description>
                <aas:langStringTextType>
                  <aas:language>en</aas:language>
                  <aas:text>The Battery Pass consortium proposes to change the definition to: "available capacity in a battery expressed as a percentage of remaining capacity" to reflect use of SoC in practice.  

DIN DKE Spec 99100 chapter reference: 6.7.2.8</aas:text>
                </aas:langStringTextType>
              </aas:description>
              <aas:value>
                <aas:property>
