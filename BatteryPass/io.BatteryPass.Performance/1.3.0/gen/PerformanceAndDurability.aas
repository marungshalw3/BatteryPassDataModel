                    </aas:langStringNameType>
                  </aas:displayName>
                  <aas:semanticId>
                    <aas:type>ExternalReference</aas:type>
                    <aas:keys>
                      <aas:key>
                        <aas:type>GlobalReference</aas:type>
                        <aas:value>urn:samm:io.BatteryPass.Performance:1.3.0#evolutionOfSelfDischargeValue</aas:value>
                      </aas:key>
                    </aas:keys>
                  </aas:semanticId>
                  <aas:valueType>xs:float</aas:valueType>
                </aas:property>
                <aas:property>
                  <aas:idShort>lastUpdate</aas:idShort>
                  <aas:displayName>
                    <aas:langStringNameType>
                      <aas:language>en</aas:language>
                      <aas:text>last update</aas:text>
                    </aas:langStringNameType>
                  </aas:displayName>
                  <aas:semanticId>
                    <aas:type>ExternalReference</aas:type>
                    <aas:keys>
                      <aas:key>
                        <aas:type>GlobalReference</aas:type>
