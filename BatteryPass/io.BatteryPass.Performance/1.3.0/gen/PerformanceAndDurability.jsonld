    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#powerCapabilityRatio",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "power capability ratio"
    },
    "samm:description" : {
