    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#roundTripEfficiencyFade",
    "@type" : "samm:Property",
    "samm:description" : {
      "@language" : "en",
      "@value" : "Energy round trip efficiency fade should be calculated using the initial round trip energy efficiency and remaining round trip energy efficiency following the formula below:\n\nRTEfade (x) = (1-RTE(x)) / RTEBOL  100\" %\" \nwhere\nx \tis the aging parameter (e.g. storage time, number of cycles, etc.);\nRTE(x) \tis the round trip energy efficiency at aging parameter x;\nRTEBOL \tis the round trip energy efficiency at begin of life.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.5"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RoundTripEfficienyFade"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RoundTripEfficienyFade",
    "@type" : "samm-c:Measurement",
    "samm:description" : {
      "@language" : "en",
      "@value" : "Art. 10: Annex IV Part A (4) (only definition); Article 14: Annex VII Part A (3)"
    },
    "samm:dataType" : {
      "@id" : "xsd:float"
    },
    "samm-c:unit" : {
      "@id" : "unit:percent"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#ExpectedLifeTime",
    "@type" : "samm-c:Measurement",
    "samm:dataType" : {
      "@id" : "xsd:short"
    },
    "samm-c:unit" : {
      "@id" : "unit:year"
    }
  }, {
