    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#currentSelfDischargingRate",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "current self discharge rate"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The current self-discharge rate is the change of the self-discharge rate in an idle state of the battery in reference conditions (temperature etc.) at aging parameter x, e.g. after a certain amount of storage time or, number of cycles.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.7"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#CurrentSelfDischargingRate"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#cRateLifeCycleTest",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "C-rate life cycle test"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The C-rate should be provided separately for both the charge and discharge of the battery, if applicable.\n\nThe exception for non-cycle applications as mentioned in \"Expected lifetime: Number of charge-discharge cycles\" should apply to this data attribute as well.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.6"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#CRateLifeCycleTest"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#PowerCapabilityRatio",
    "@type" : "samm-c:Measurement",
    "samm:description" : {
      "@language" : "en",
      "@value" : "Ratio between nominal allowed battery power (W) and battery energy (Wh)."
    },
    "samm:dataType" : {
      "@id" : "xsd:float"
    },
    "samm-c:unit" : {
      "@id" : "unit:percent"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RemainingRoundTripEnergyEfficiency",
    "@type" : "samm-c:SingleEntity",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "remaining round trip energy efficiency"
    },
    "samm:dataType" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RemainingRoundTripEnergyEfficiencyEntity"
    }
  }, {
