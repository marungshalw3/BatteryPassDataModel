    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RemainingRoundTripEnergyEfficiencyValue"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#ratedCapacity",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "rated capacity"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "Rated capacity is the total number of ampere-hours (Ah) that can be withdrawn from a fully charged battery under reference conditions (see BattReg Annex IV (1)).\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.2"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RatedCapacity"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#stateOfCharge",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "SoC"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The Battery Pass consortium proposes to change the definition to: \"available capacity in a battery expressed as a percentage of remaining capacity\" to reflect use of SoC in practice.  \n\nDIN DKE Spec 99100 chapter reference: 6.7.2.8"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#StateOfCharge"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#capacityThresholdForExhaustion",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "capacity threshold for exhaustion"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The percentage of SOCE, above which the battery is still considered operational as EV battery in its current life, as provided by the economic operator.\n\nDIN DKE Spec 99100 chapter reference: 6.7.6.9"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#CapacityThresholdForExhaustion"
    }
  }, {
