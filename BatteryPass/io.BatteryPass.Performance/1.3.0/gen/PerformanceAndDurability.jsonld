    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#evolutionOfSelfDischarge",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "evolution of self discharge"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "Evolution of self-discharge rates is the change of self-discharge over time and usage, as percentage calculated from the initial and current self-discharge rate.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.8"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#EvolutionOfSelfDischarge"
    }
  }, {
