      "@value" : "temperature information"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The battery passport must include periodically recorded information on the operating environmental conditions, including temperature.\n\nDIN DKE Spec 99100 chapter reference: 6.7.7.5 - 8"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#TemperatureInformation"
    }
