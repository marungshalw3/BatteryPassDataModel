  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#remainingRoundTripEnergyEfficiency",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "remaining round trip energy efficiency"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The battery passport shall include information, where possible, about the remaining round trip energy efficiency as information on the state of health of the battery \n\nThe update frequency of remaining round trip energy efficiency should be aligned with the update frequency of round trip energy efficiency fade and should be provided upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.4.4"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RemainingRoundTripEnergyEfficiency"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#ratedMaximumPower",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "rated maximum power"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "This data point describes the value of maximum permitted power the battery is rated for and reflects the data relevant for power limits.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.2"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RatedMaximumPower"
    }
  }, {
