    "samm:dataType" : {
      "@id" : "xsd:float"
    },
    "samm-c:unit" : {
      "@id" : "unit:percent"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RemainingRoundTripEnergyEfficiencyEntity",
    "@type" : "samm:Entity",
    "samm:properties" : {
      "@list" : [ {
        "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#remainingRoundTripEnergyEfficiencyValue"
      }, {
        "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#lastUpdate"
      } ]
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#ohmicResistance",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "resistance"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "Initial (Pre-Use) internal resistance on battery pack level. \n\nDefinition of internal resistance should differ from regulation definition, as \"opposition\" is not an electrotechnical term and may be based on IEV 131-12-04: \"internal resistance means the absolute value of the quotient of the voltage drop between the terminals by the electric current increase in the battery circuit during a current pulse\""
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#OhimcResistance"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#OhimcResistance",
    "@type" : "samm-c:Measurement",
    "samm:dataType" : {
      "@id" : "xsd:double"
    },
    "samm-c:unit" : {
      "@id" : "unit:ohm"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#negativeEvent",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "negative event"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "Negative event, such as an accident. No further definition provided by regulation."
    },
    "samm:characteristic" : {
      "@id" : "samm-c:Text"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#ratedEnergy",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "rated energy"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The certified usable battery energy is the usable battery energy according to the procedure in the UN GTR No 22 as determined during the certification of the vehicle.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.5"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RatedEnergy"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#RatedEnergy",
    "@type" : "samm-c:Measurement",
    "samm:dataType" : {
      "@id" : "xsd:float"
    },
    "samm-c:unit" : {
      "@id" : "unit:kilowattHour"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#initialSelfDischarge",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "initial self discharge"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "Initial self-discharge in % of capacity per unit of time in defined conditions (temperature range etc) as pre-use metric. \n\nDIN DKE Spec 99100 chapter reference: 6.7.4.6"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#InitialSelfDischarge"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#capacityFade",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "capacity fade"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The capacity fade is the Decrease over time and upon usage in the amount of charge that a battery can deliver at the rated voltage, with respect to the original rated capacity (see BattReg Annex IV (2)) as declared by the manufacturer.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.4"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#CapacityFade"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#CapacityFade",
    "@type" : "samm-c:SingleEntity",
    "samm:dataType" : {
