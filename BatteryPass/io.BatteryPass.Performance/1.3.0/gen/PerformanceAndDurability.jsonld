    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#batteryCondition",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "battery condition"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "'- Expected battery lifetime expressed in cycles, and reference test used.\n- Their expected life-time under the reference conditions for which they have been designed in terms of cycles, except for non-cycle applications, and calendar years."
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#BatteryCondition"
