    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#cRate",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "C-rate"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "As a non-mandatory data point the battery passport should include the ratio between nominal battery power in W and battery energy in Wh. It aims to provide an indication of the applicable discharge and charge rate in terms of rated capacity (C-rate) (see BattReg Annex IV Part B(2)).\n\nThe update interval should be upon placement on the market and upon change of the battery status.\n\nDIN DKE Spec 99100 chapter reference: 6.7.3.6"
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#CRate"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#StateOfChargeValue",
    "@type" : "samm-c:Measurement",
    "samm:preferredName" : {
