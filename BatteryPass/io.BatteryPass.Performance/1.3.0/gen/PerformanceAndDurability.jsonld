    "@type" : "samm:Entity",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "internal resistance"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The internal resistance is a quotient of change of voltage of a battery by the corresponding change in discharge current under specified conditions (IEV 482 03 36)."
    },
