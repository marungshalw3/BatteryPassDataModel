    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#BatteryCondition",
    "@type" : "samm-c:SingleEntity",
    "samm:description" : {
      "@language" : "en",
      "@value" : "'- Expected battery lifetime expressed in cycles, and reference test used.\n- Their expected life-time under the reference conditions for which they have been designed in terms of cycles, except for non-cycle applications, and calendar years."
    },
    "samm:dataType" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#BatteryConditionEntity"
    }
  }, {
    "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#timeExtremeHighTemp",
    "@type" : "samm:Property",
    "samm:preferredName" : {
      "@language" : "en",
      "@value" : "time extreme high temperature"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "Cumulated time spent above the given upper boundary of temperature."
    },
    "samm:characteristic" : {
      "@id" : "urn:samm:io.BatteryPass.Performance:1.3.0#TimeExtremeHighTemp"
    }
  }, {
