      "@language" : "en",
      "@value" : "remaining capacity"
    },
    "samm:description" : {
      "@language" : "en",
      "@value" : "The in-use data attribute on capacity, corresponding with the definition of rated capacity.\n\nDIN DKE Spec 99100 chapter reference: 6.7.2.3"
    },
    "samm:characteristic" : {
