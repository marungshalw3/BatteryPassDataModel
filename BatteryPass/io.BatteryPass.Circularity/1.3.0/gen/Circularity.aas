        </aas:submodelElementList>
        <aas:submodelElementCollection>
          <aas:idShort>SafetyMeasuresEntity</aas:idShort>
          <aas:displayName>
            <aas:langStringNameType>
              <aas:language>en</aas:language>
              <aas:text>safety measures</aas:text>
            </aas:langStringNameType>
          </aas:displayName>
          <aas:description>
            <aas:langStringTextType>
              <aas:language>en</aas:language>
              <aas:text>Safety measures and instructions should also take past negative and extreme events as well as the separate data attributes ?battery status? and ?battery composition/chemistry? into account.

DIN DKE Spec 99100 chapter reference: 6.6.1.5</aas:text>
            </aas:langStringTextType>
          </aas:description>
          <aas:value>
            <aas:property>
              <aas:idShort>safetyInstructions</aas:idShort>
