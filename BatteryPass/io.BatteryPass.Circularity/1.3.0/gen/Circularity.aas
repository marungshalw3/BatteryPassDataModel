                <aas:langStringTextType>
                  <aas:language>en</aas:language>
                  <aas:text>Usable extinguishing agents refering to classes of extinguishers (A, B, C, D, K).EUBR: Annex XIII (1a) ? Annex VI Part A (9)</aas:text>
                </aas:langStringTextType>
              </aas:description>
              <aas:semanticId>
                <aas:type>ExternalReference</aas:type>
                <aas:keys>
                  <aas:key>
